# bash completion for chronos
_chronos()
{
    local cur prev words cword
    _init_completion || return

    local opts="-h --help --version -b --backup -r --restore -a --all -c --config -n --dry-run -y --yes --backup-dir --restore-root --from-version --list-versions --show-config --list-targets --extra-info --no-extra-info"
    local modes="backup restore bak rst"
    local targets="all root home efi esp boot / /home /efi /boot /boot/efi"

    case "$prev" in
        -c|--config)
            _filedir toml
            return
            ;;
        --backup-dir|--restore-root)
            _filedir -d
            return
            ;;
        -b|--backup|-r|--restore|backup|restore|bak|rst)
            COMPREPLY=( $(compgen -W "$targets" -- "$cur") )
            return
            ;;
    esac

    if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "$opts" -- "$cur") )
    else
        COMPREPLY=( $(compgen -W "$modes $targets" -- "$cur") )
    fi
}
complete -F _chronos chronos
